{
  "version": 2,
  "builds": [
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/audit.js",
      "use": "@vercel/edge"
    }
  ],
  "routes": [
    {
      "src": "/api/audit",
      "dest": "/api/audit.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
